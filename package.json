{
  "name": "rv-appliance-code-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build && node scripts/generate-static.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test:unit": "vitest run",
    "test:browser": "playwright test",
    "test": "npm run validate:corpus && npm run test:unit",
    "validate:corpus": "node scripts/validate-corpus.mjs",
    "source:audit": "node scripts/validate-corpus.mjs --audit",
    "traffic:report": "node scripts/traffic-report.mjs",
    "traffic:monitor": "node scripts/traffic-report.mjs --watch",
    "traffic:gsc:verify:dry-run": "node scripts/gsc-verify-url-prefix.mjs --dry-run",
    "traffic:gsc:verify": "node scripts/gsc-verify-url-prefix.mjs --verify",
    "traffic:gsc:dry-run": "npm run build && node scripts/gsc-submit-sitemap.mjs --dry-run",
    "traffic:gsc:submit": "npm run build && node scripts/gsc-submit-sitemap.mjs --submit",
    "serve:dist": "node scripts/serve-static.mjs",
    "verify:runtime": "npm run build && npm run test:browser"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.2",
    "vite": "8.0.16",
    "typescript": "6.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "lucide-react": "1.17.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "25.0.2",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "vitest": "4.1.8"
  }
}
